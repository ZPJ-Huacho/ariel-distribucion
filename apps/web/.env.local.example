# Conexión del front al Worker
#
# Sin estas variables apunta a http://localhost:8788 (wrangler dev local).
# Para probar el frontend local contra el Worker desplegado en Cloudflare,
# copia este archivo a apps/web/.env.local y reinicia `pnpm dev`.

# Server-side (RSC fetch desde Next):
API_BASE_URL=https://mercabana-api.erickpineda001.workers.dev

# Client-side (browser fetch desde componentes "use client"):
NEXT_PUBLIC_API_BASE_URL=https://mercabana-api.erickpineda001.workers.dev

# Tenant por defecto cuando no hay subdominio (ej. http://localhost:3000).
# Visitando http://frutas.localhost:3000 esto no aplica: el middleware
# extrae "frutas" del Host.
# DEFAULT_TENANT_SLUG=frutas
# NEXT_PUBLIC_DEFAULT_TENANT=frutas
